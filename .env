APP_ENV=development
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dx_engine
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_DRIVER=database
QUEUE_WORKER_ID=dx-node-1

LOG_CHANNEL=file
LOG_LEVEL=debug

WEBHOOK_RETRY_MAX=3
WEBHOOK_RETRY_BACKOFF_SECONDS=60

PDF_STORAGE_PATH=storage/exports/
EXPORT_STORAGE_PATH=storage/exports/
