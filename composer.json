{
  "name": "dx-engine/framework",
  "description": "DX Engine Framework - Center-Out enterprise PHP operating system",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.1",
    "doctrine/dbal": "^3.0",
    "guzzlehttp/guzzle": "^7.0",
    "phpoffice/phpspreadsheet": "^2.0",
    "dompdf/dompdf": "^2.0",
    "vlucas/phpdotenv": "^5.0",
    "ramsey/uuid": "^4.0",
    "monolog/monolog": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.0",
    "squizlabs/php_codesniffer": "^3.0",
    "fakerphp/faker": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "DxEngine\\Core\\": "src/Core/",
      "DxEngine\\App\\": "src/App/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DxEngine\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse",
    "lint": "phpcs",
    "migrate": "php bin/console migrate",
    "seed": "php bin/console seed"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
